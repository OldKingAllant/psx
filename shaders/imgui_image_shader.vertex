#version 460 core

layout (location = 0) in vec2 Position;
layout (location = 1) in vec2 UV;
layout (location = 2) in vec4 Color;

out vec2 Frag_UV;
out vec4 Frag_Color;

void main() {
    Frag_UV = UV;
    Frag_Color = Color;

    float x = Position.x * 2.0 - 1.0;
    float y = 1.0 - Position.y * 2.0;

    gl_Position = vec4(x,y,0,1);
}